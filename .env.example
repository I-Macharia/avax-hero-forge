# Avalanche network — Fuji testnet by default
VITE_AVALANCHE_RPC_URL="https://api.avax-test.network/ext/bc/C/rpc"
VITE_AVALANCHE_CHAIN_ID=43113
VITE_EXPLORER_URL="https://testnet.snowtrace.io"

# Deployed MiniHackAchievement contract (replace after deploy — see contracts/README.md)
VITE_CONTRACT_ADDRESS="0x0000000000000000000000000000000000000000"

# Comma-separated wallet addresses allowed to sign on-chain batch mints
VITE_ADMIN_WALLETS=""

# Server-side admin minter (signs mintTo / batchMintTo / adminTransfer txs).
# Set this in Lovable Cloud secrets, NEVER commit. Wallet must hold MINTER_ROLE on the contract.
ADMIN_MINTER_PRIVATE_KEY=""

# Tally integration — used by /api/public/tally-webhook and the admin "Resync" button.
TALLY_WEBHOOK_SECRET=""
TALLY_API_KEY=""

# Supabase / Lovable Cloud keys are auto-injected — no need to set manually.
